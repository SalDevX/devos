##
## DevOS — Arch Linux mirrorlist (live ISO defaults)
##
## These worldwide-tier servers make pacman work immediately on first boot,
## before reflector.service has had a chance to re-rank mirrors for the
## user's actual region. reflector.service (enabled in customize_airootfs.sh)
## overwrites this file with location-optimal mirrors once network is up.
##

## Worldwide (Arch GeoDNS — routes to nearest official mirror)
Server = https://geo.mirror.pkgbuild.com/$repo/os/$arch

## United States
Server = https://mirrors.kernel.org/archlinux/$repo/os/$arch
Server = https://mirror.rackspace.com/archlinux/$repo/os/$arch
